{% extends "base.html.twig" %}

{% block title %}Cart{% endblock %}

{% block body %}
    <h1>Cart</h1>

    {% for cartItem in cartItems %}
        <div>
            <h3>{{ cartItem.product.name }}</h3>
            <p>Quantity: {{ cartItem.quantity }}</p>
        </div>
    {% endfor %}
{% endblock %}
