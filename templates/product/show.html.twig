{% extends "base.html.twig" %}

{% block title %}{{ product.name }} | Generic E-Commerce{% endblock %}

{% block body %}
    <div class="row g-4">
        <div class="col-12 col-md-5">
            <div class="card shadow-sm">
                <img src="{{ asset('images/' ~ product.imagePath) }}" class="card-img-top" alt="{{ product.name }}" style="height: 350px; object-fit: cover;">
            </div>
        </div>

        <div class="col-12 col-md-7">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h1 class="h3">{{ product.name }}</h1>
                    <p class="fs-4 fw-semibold text-primary mb-4">${{ product.price|number_format(2, '.', ',') }}</p>

                    <form method="post" action="{{ path('cart_add', {id: product.id}) }}" class="mt-auto">
                        <input type="hidden" name="token" value="{{ csrf_token('product-add-to-cart-' ~ product.id) }}">
                        <button type="submit" class="btn btn-primary">Add To Cart</button>
                        <a href="{{ path('product_index') }}" class="btn btn-outline-secondary ms-2">Back to Products</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}