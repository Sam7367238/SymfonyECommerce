{% extends "base.html.twig" %}

{% block title %}Delete Product | Generic E-Commerce{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-12 col-lg-6">
            <div class="card border-danger shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h3 text-danger mb-3">Delete Product</h1>
                    <p class="mb-4">Are you sure you want to delete <strong>{{ product.name }}</strong>?</p>

                    <form method="post" class="d-flex gap-2">
                        <input type="hidden" name="token" value="{{ csrf_token('delete-product-' ~ product.id) }}">
                        <a href="{{ path('admin_product_index') }}" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-danger">Confirm</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}