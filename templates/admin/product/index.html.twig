{% extends "base.html.twig" %}

{% block title %}Manage Products | Generic E-Commerce{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Manage Products</h1>
        <a href="{{ path('admin_product_new') }}" class="btn btn-primary">New Product</a>
    </div>

    {% if products|length > 0 %}
        <div class="table-responsive bg-white border rounded shadow-sm">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Image Path</th>
                        <th>Price</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for product in products %}
                        <tr>
                            <td>{{ product.name }}</td>
                            <td><code>{{ product.imagePath }}</code></td>
                            <td>${{ product.price|number_format(2, '.', ',') }}</td>
                            <td class="text-end">
                                <a href="{{ path('admin_product_edit', {id: product.id}) }}" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a href="{{ path('admin_product_delete', {id: product.id}) }}" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="mt-4 d-flex justify-content-center">
            {{ knp_pagination_render(products, "@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig") }}
        </div>
    {% else %}
        <div class="alert alert-secondary mb-0">No products found.</div>
    {% endif %}
{% endblock %}
